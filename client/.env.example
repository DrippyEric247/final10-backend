# Stripe Publishable Key (for payment processing)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# API Base URL
REACT_APP_API_URL=http://localhost:5000

# Optional alias for deployments that provide Vite-style env names.
# Final10 reads either REACT_APP_API_URL or VITE_API_URL.
VITE_API_URL=http://localhost:5000

# Donation tiers: $5 · $25 Support Development · $100 · Custom (hosted Stripe Payment Links)
# Leave blank to show "Coming Soon" on that button.
REACT_APP_DONATION_LINK_5=https://buy.stripe.com/00w14nao54TK3tJdOF83C02
REACT_APP_DONATION_LINK_25=https://buy.stripe.com/3cIcN52VD71S9S79yp83C03
REACT_APP_DONATION_LINK_100=https://buy.stripe.com/bJe28r67Pcmc0hx11T83C01
REACT_APP_DONATION_LINK_CUSTOM=https://buy.stripe.com/6oUeVdeEl9a08O38ul83C04

