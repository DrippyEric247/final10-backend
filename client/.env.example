# Stripe Publishable Key (for payment processing)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# API Base URL
REACT_APP_API_URL=http://localhost:5000

# Optional alias for deployments that provide Vite-style env names.
# Final10 reads either REACT_APP_API_URL or VITE_API_URL.
VITE_API_URL=http://localhost:5000

# Optional donation links (hosted checkout — Stripe Payment Links, PayPal, etc.)
# Leave blank to show "Coming Soon" on Home donation buttons.
REACT_APP_DONATION_LINK_5=
REACT_APP_DONATION_LINK_10=
REACT_APP_DONATION_LINK_25=
REACT_APP_DONATION_LINK_CUSTOM=


