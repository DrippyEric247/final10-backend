# ---------------------------------------------------------------------------
# Final10 server — .env.example
#
# Copy this file to `server/.env` for local development. NEVER commit a
# real .env, and never paste production secrets into any file inside the
# repo. In production (Railway), set these as environment variables in
# the service dashboard, not in a file.
#
# The server refuses to boot in production if any of these look like
# placeholders (see `server/config/envValidation.js`).
# ---------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
# Production — whitelist both apex and www for CORS (also built into server/middleware/security.js):
# CLIENT_URL=https://www.final10.app
# CORS_ORIGINS=https://final10.app,https://www.final10.app

# --- Database ---
# Use a dedicated user + database per environment. Never share prod Mongo
# URIs with staging or local.
MONGODB_URI=mongodb://localhost:27017/final10

# --- JWT ---
# Must be at least 32 characters of high-entropy random data in production.
# Generate with: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-locally-but-never-in-prod

# --- Social sign-in (Google + Apple OAuth) ---
# Optional. Buttons are only shown when a provider's full set of values is
# present (the client checks GET /api/auth/providers). See docs/SOCIAL_AUTH_SETUP.md.
#
# Google (Google Cloud Console → APIs & Services → Credentials → OAuth client ID, type "Web application"):
#   Authorized redirect URI must EXACTLY match GOOGLE_CALLBACK_URL below.
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=replace_me
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
#   Production: https://api.final10.app/api/auth/google/callback
#
# Apple (Apple Developer → Certificates, Identifiers & Profiles):
#   APPLE_CLIENT_ID   = the Services ID identifier (e.g. app.final10.signin), NOT the app bundle id
#   APPLE_TEAM_ID     = your 10-char Apple Team ID
#   APPLE_KEY_ID      = the Key ID of the "Sign in with Apple" key (.p8)
#   APPLE_PRIVATE_KEY = contents of the AuthKey_XXXX.p8 (PEM). Use literal \n for newlines
#                       on a single line, or a base64 of the whole file.
#   APPLE_CALLBACK_URL must EXACTLY match a Return URL on the Services ID, and Apple
#   requires HTTPS (no localhost) — use a tunnel (ngrok/Cloudflare) for local testing.
# APPLE_CLIENT_ID=app.final10.signin
# APPLE_TEAM_ID=ABCDE12345
# APPLE_KEY_ID=ABC123DEFG
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----\n"
# APPLE_CALLBACK_URL=https://api.final10.app/api/auth/apple/callback

# --- One-time owner grant bootstrap (production only) ---
# When set (16+ chars), POST /api/owner/grant-founding-access accepts
# header X-Owner-Grant-Secret without a superadmin JWT. Remove after use.
# Generate with: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# OWNER_GRANT_SECRET=

# --- Stripe (only needed if FINAL10_REQUIRE_STRIPE=true) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PREMIUM_PRICE_ID=price_replace_me

# --- eBay Browse API (only needed if FINAL10_REQUIRE_EBAY_APP_CREDENTIALS=true) ---
EBAY_CLIENT_ID=replace_me
EBAY_CLIENT_SECRET=replace_me
EBAY_REDIRECT_URI=https://your-production-api.example.com/api/ebay-auth/callback
EBAY_ENV=production
EBAY_SCOPE=https://api.ebay.com/oauth/api_scope/buy.browse

# --- True Market Value engine ---
# Set to `true` only after eBay has approved your app for the
# Marketplace Insights API (limited release). When true, the engine pulls
# real recently-sold comps; otherwise it falls back to actively-listed
# comps with strict outlier trimming. Either way, the median is used as
# the True Market Value (NOT the live listing price).
EBAY_MARKETPLACE_INSIGHTS_ENABLED=false
# Cache TTL for comp lookups, ms (default 15 min, 1-60 min allowed).
MARKET_VALUE_CACHE_TTL_MS=900000
# Max parallel eBay comp lookups during enrichment of a single search page.
MARKET_VALUE_ENRICH_CONCURRENCY=4

# --- SavvyShield ---
SHIELD_API_URL=http://localhost:5000/api/shield
SHIELD_API_KEY=replace_me
SHIELD_WEBHOOK_SECRET=replace_me

# --- Optional integrations ---
YT_API_KEY=replace_me
OPENAI_API_KEY=replace_me

# --- Savvy Scout alert email ---
# Preferred: Resend (HTTPS API — works on Railway without SMTP egress issues)
# ALERT_EMAIL_ENABLED=true
# ALERT_EMAIL_DEFAULT=true  # optional override; production defaults to true when unset
# DISABLE_SAVVY_SCOUT_SCAN=true
# SAVVY_SCOUT_MAX_LANES_PER_SCAN=24
# RESEND_API_KEY=re_xxxxxxxx
#
# IMPORTANT: Do NOT use onboarding@resend.dev in production — Resend only delivers
# sandbox mail to your Resend account email. Verify your domain in Resend first:
#   Resend Dashboard → Domains → Add final10.app (SPF + DKIM DNS records)
#
# RESEND_VERIFIED_DOMAIN=final10.app
# RESEND_FROM_LOCAL=scout
# RESEND_FROM_NAME=Savvy Scout
# EMAIL_FROM=Savvy Scout <scout@final10.app>
#
# Email image assets (Gmail requires public https URLs):
# EMAIL_ASSETS_BASE_URL=https://final10.app
# EMAIL_PRODUCT_FALLBACK_URL=https://final10.app/assets/email/savvy-scout-hero.png
#
# Dev-only sandbox (optional):
# RESEND_ALLOW_SANDBOX_FROM=true
# EMAIL_FROM=onboarding@resend.dev
#
# Fallback: SMTP (used only when RESEND_API_KEY is not set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM="Savvy Scout <you@gmail.com>"
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true

# --- Beta alert test pipeline (temporary — remove after launch) ---
# ALERT_TEST_MODE_ENABLED=true
# POINTS_EVENT_MULTIPLIER=2
# DOUBLE_POINTS_EVENT_ACTIVE=true
# CLIENT_URL=https://final10.app
# SMTP_TIMEOUT_MS=60000
#
# Public Resend test (no JWT — requires secret header):
# ALERT_TEST_PUBLIC_SECRET=your-long-random-secret-min-16-chars
#
# Test delivery:
#   GET  /api/email/status
#   POST /api/email/test  { "to": "you@example.com" }
#   (JWT → own email only, or X-Owner-Grant-Secret → any recipient)
#
#   POST /api/test-alert/public  { "to": "you@example.com" }
#   Header: X-Alert-Test-Secret: <ALERT_TEST_PUBLIC_SECRET>
#   Query: ?emailOnly=true  (default — Savvy Scout template test)
#   Query: ?emailOnly=false — full PS5 pipeline (account must exist for "to")

# --- Referral economy (safe to tune) ---
REFERRAL_BONUS=5000
REFEREE_SIGNUP_BONUS=2500
REFERRAL_CAP_PER_USER=500
REFERRAL_MAX_PER_REFEREE=1
REFERRAL_POINTS_FIRST10=5000
REFERRAL_CASH_FIRST10=50
REFERRAL_POINTS_AFTER10=2500
REFERRAL_POINTS=5000
REFERRAL_DAILY_CAP=10
DAILY_EARN_CAP=200

# --- Feature flags — DEV ONLY ---
# These are silently ignored in production (NODE_ENV=production). Do not
# rely on them for deployed behavior.
#   DISABLE_EBAY_AUTH=true              # skip JWT on /api/ebay* (dev only)
#   ALLOW_PROGRESSION_TRUST_BYPASS=true # skip scan-deck / bid-flow tokens (dev only)
#   ALLOW_BP_CLIENT_PREMIUM_UNLOCK=true # let client toggle battle-pass premium (dev only)

# --- Required-in-production gates ---
# Set to `true` when the corresponding integration must be live.
FINAL10_REQUIRE_EBAY_APP_CREDENTIALS=false
FINAL10_REQUIRE_STRIPE=false
