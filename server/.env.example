# ---------------------------------------------------------------------------
# Final10 server — .env.example
#
# Copy this file to `server/.env` for local development. NEVER commit a
# real .env, and never paste production secrets into any file inside the
# repo. In production (Railway), set these as environment variables in
# the service dashboard, not in a file.
#
# The server refuses to boot in production if any of these look like
# placeholders (see `server/config/envValidation.js`).
# ---------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# --- Database ---
# Use a dedicated user + database per environment. Never share prod Mongo
# URIs with staging or local.
MONGODB_URI=mongodb://localhost:27017/final10

# --- JWT ---
# Must be at least 32 characters of high-entropy random data in production.
# Generate with: `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`
JWT_SECRET=change-me-locally-but-never-in-prod

# --- Stripe (only needed if FINAL10_REQUIRE_STRIPE=true) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PREMIUM_PRICE_ID=price_replace_me

# --- eBay Browse API (only needed if FINAL10_REQUIRE_EBAY_APP_CREDENTIALS=true) ---
EBAY_CLIENT_ID=replace_me
EBAY_CLIENT_SECRET=replace_me
EBAY_ENV=production
EBAY_SCOPE=https://api.ebay.com/oauth/api_scope

# --- SavvyShield ---
SHIELD_API_URL=http://localhost:5000/api/shield
SHIELD_API_KEY=replace_me
SHIELD_WEBHOOK_SECRET=replace_me

# --- Optional integrations ---
YT_API_KEY=replace_me
OPENAI_API_KEY=replace_me

# --- Referral economy (safe to tune) ---
REFERRAL_BONUS=5000
REFEREE_SIGNUP_BONUS=2500
REFERRAL_CAP_PER_USER=500
REFERRAL_MAX_PER_REFEREE=1
REFERRAL_POINTS_FIRST10=5000
REFERRAL_CASH_FIRST10=50
REFERRAL_POINTS_AFTER10=2500
REFERRAL_POINTS=5000
REFERRAL_DAILY_CAP=10
DAILY_EARN_CAP=200

# --- Feature flags — DEV ONLY ---
# These are silently ignored in production (NODE_ENV=production). Do not
# rely on them for deployed behavior.
#   DISABLE_EBAY_AUTH=true              # skip JWT on /api/ebay* (dev only)
#   ALLOW_PROGRESSION_TRUST_BYPASS=true # skip scan-deck / bid-flow tokens (dev only)
#   ALLOW_BP_CLIENT_PREMIUM_UNLOCK=true # let client toggle battle-pass premium (dev only)

# --- Required-in-production gates ---
# Set to `true` when the corresponding integration must be live.
FINAL10_REQUIRE_EBAY_APP_CREDENTIALS=false
FINAL10_REQUIRE_STRIPE=false
