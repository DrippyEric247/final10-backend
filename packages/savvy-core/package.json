{
  "name": "@savvy/core",
  "version": "0.1.0",
  "private": true,
  "description": "Savvy Universe shared core — Phase 1 leaf modules (constants, events, tokens). Final10 client unchanged until Phase 2 re-exports.",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./config/savvyRewards": {
      "types": "./src/config/savvyRewards.d.ts",
      "import": "./src/config/savvyRewards.js",
      "require": "./src/config/savvyRewards.js",
      "default": "./src/config/savvyRewards.js"
    },
    "./config/scoutBranding": {
      "import": "./src/config/scoutBranding.js",
      "require": "./src/config/scoutBranding.js",
      "default": "./src/config/scoutBranding.js"
    },
    "./events/universeEvents": {
      "import": "./src/events/universeEvents.js",
      "require": "./src/events/universeEvents.js",
      "default": "./src/events/universeEvents.js"
    },
    "./tokens/theme.css": "./src/tokens/theme.css"
  },
  "scripts": {
    "verify": "node scripts/verify-parity.js"
  },
  "files": [
    "src",
    "scripts",
    "README.md"
  ]
}
